#!/usr/bin/env bash
# Lightweight launcher that delegates to the Python implementation
PY=python3
if command -v python3 >/dev/null 2>&1; then
  PY=python3
elif command -v python >/dev/null 2>&1; then
  PY=python
else
  echo "Python not found. Please install Python 3." >&2
  exit 1
fi
exec "$PY" "$(dirname "$0")/cmake_util/cbuild.py" "$@"

